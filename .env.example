# Reference only — ./install.sh generates the real file at /etc/blinkray.env
# automatically. Use this file for local dev runs (see README "Локальный
# запуск для разработки"), or as a starting point if you're doing a manual
# install instead of running install.sh.

PANEL_PASSWORD=change-me-to-a-strong-password
PANEL_HOST=0.0.0.0
PANEL_PORT=10077

# Where the panel keeps its own state (settings.json, clients.json, certs, apk).
# PANEL_DATA_DIR=/root/blinkray/data

# xray-core binary and the config file the xray.service unit runs with.
# XRAY_BIN=/usr/local/bin/xray
# XRAY_CONFIG_PATH=/root/blinkray/data/xray/config.json
# XRAY_SERVICE_NAME=xray
